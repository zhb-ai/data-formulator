# 通过环境变量提供前端配置
# 也可以在启动时通过命令行参数覆盖这些设置：
#   python -m data_formulator -p 5000 --exec-python-in-subprocess true --disable-display-keys true

LOG_LEVEL=INFO # 应用日志级别: DEBUG / INFO / WARNING / ERROR。仅影响 data_formulator 自身模块，第三方库始终为 WARNING。

DISABLE_DISPLAY_KEYS=false # 设为 true 时，前端不显示 API 密钥输入框。服务端配置的模型 的API密钥永远不会显示在前端。

EXEC_PYTHON_IN_SUBPROCESS=false # 设为 true 时，Python 代码将在子进程中执行，避免主进程崩溃，但会增加响应时间

LOCAL_DB_DIR= # 本地数据库存储目录，留空则使用系统临时目录

# Apache Superset 集成（留空则禁用）
SUPERSET_URL=http://YourSupersetURL # 例如 http://192.168.1.10:8088

# FLASK_SECRET_KEY= 无需手动填写，系统首次启动时会自动生成并写入 .env 文件。
#   迁移系统时需保留原来自动生成的密钥，以保持匿名用户 session 与数据库的对应关系。
